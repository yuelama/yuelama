/* 文章场景相关 */
.page.data-v-8a71bbb4 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F3F4F6;
}
.order-list.data-v-8a71bbb4 {
  flex: 1;
  padding: 24rpx 30rpx 0;
}
.list-bottom.data-v-8a71bbb4 {
  height: 30rpx;
}
/* 订单卡片 */
.order-card.data-v-8a71bbb4 {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.order-card-header.data-v-8a71bbb4 {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 16rpx;
}
.order-card-header-left.data-v-8a71bbb4 {
  flex: 1;
  min-width: 0;
}
.order-title.data-v-8a71bbb4 {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.order-instructor.data-v-8a71bbb4 {
  font-size: 26rpx;
  color: #6B7280;
}
/* 状态徽章 */
.status-badge.data-v-8a71bbb4 {
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
}
.status-pending.data-v-8a71bbb4 {
  background: #FEF3C7;
}
.status-pending .status-text.data-v-8a71bbb4 {
  color: #D97706;
}
.status-confirmed.data-v-8a71bbb4 {
  background: #D1FAE5;
}
.status-confirmed .status-text.data-v-8a71bbb4 {
  color: #059669;
}
.status-cancelled.data-v-8a71bbb4 {
  background: #F3F4F6;
}
.status-cancelled .status-text.data-v-8a71bbb4 {
  color: #9CA3AF;
}
.status-text.data-v-8a71bbb4 {
  font-size: 22rpx;
  font-weight: 500;
}
/* 订单信息 */
.order-meta.data-v-8a71bbb4 {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.meta-row.data-v-8a71bbb4 {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}
.meta-text.data-v-8a71bbb4 {
  font-size: 26rpx;
  color: #6B7280;
}
/* 卡片底部 */
.order-card-footer.data-v-8a71bbb4 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
}
.order-price.data-v-8a71bbb4 {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563EB;
}
.cancel-btn.data-v-8a71bbb4 {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  color: #374151;
  font-size: 26rpx;
  border: 1rpx solid #D1D5DB;
  border-radius: 12rpx;
  text-align: center;
}
.cancel-btn.data-v-8a71bbb4::after {
  border: none;
}
/* 空状态 */
.empty-state.data-v-8a71bbb4 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 0 120rpx;
}
.empty-icon-wrap.data-v-8a71bbb4 {
  width: 160rpx;
  height: 160rpx;
  background: #F3F4F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}
.empty-title.data-v-8a71bbb4 {
  font-size: 30rpx;
  color: #6B7280;
  margin-bottom: 10rpx;
}
.empty-sub.data-v-8a71bbb4 {
  font-size: 26rpx;
  color: #9CA3AF;
}
