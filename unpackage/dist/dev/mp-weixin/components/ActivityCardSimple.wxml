<view data-event-opts="{{[['tap',[['$emit',['open','$0'],['activity']]]]]}}" class="card data-v-283cb56c" bindtap="__e"><image class="thumb data-v-283cb56c" src="{{activity.image}}" mode="aspectFill"></image><view class="info data-v-283cb56c"><view class="row data-v-283cb56c"><text class="title data-v-283cb56c">{{activity.title}}</text><text class="level data-v-283cb56c">{{activity.level}}</text></view><text class="meta data-v-283cb56c">{{activity.time+" · "+activity.organizer}}</text><view class="bottom-row data-v-283cb56c"><view class="progress-wrap data-v-283cb56c"><view class="bar data-v-283cb56c"><view class="fill data-v-283cb56c" style="{{'width:'+(100*(activity.participants/activity.capacity)+'%')+';'}}"></view></view><text class="remain data-v-283cb56c">{{"剩余 "+$root.g0+" 名"}}</text></view><button data-event-opts="{{[['tap',[['$emit',['join','$0'],['activity']]]]]}}" class="join data-v-283cb56c" catchtap="__e">报名</button></view></view></view>